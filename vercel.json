{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://symbioai-backend.onrender.com/api/:path*"
    }
  ],
  "env": {
    "VITE_API_URL": "https://symbioai-backend.onrender.com"
  }
}
