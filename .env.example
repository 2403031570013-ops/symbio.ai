# Frontend
VITE_API_URL=http://127.0.0.1:8000/api
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_BASE_PATH=/

# Backend
SECRET_KEY=replace-with-a-strong-random-secret
DATABASE_URL=sqlite:///./backend/symbioai.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
ENVIRONMENT=development
SECURE_COOKIES=false
FRONTEND_URL=http://localhost:5173
RATE_LIMIT_PER_MINUTE=120
RESEND_API_KEY=replace-with-your-resend-api-key

# SMTP email provider
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=apikey-or-user
SMTP_PASSWORD=replace-with-provider-password
SMTP_FROM_EMAIL=no-reply@symbioai.com
SMTP_USE_TLS=true

# S3-compatible object storage
STORAGE_PROVIDER=s3
S3_BUCKET=symbioai-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=replace-with-access-key
S3_SECRET_ACCESS_KEY=replace-with-secret-key
S3_ENDPOINT_URL=
S3_PUBLIC_BASE_URL=
